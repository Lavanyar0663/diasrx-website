import React, { useState, useEffect } from 'react';
import { useNavigate, useParams } from 'react-router-dom';
import DoctorLayout from '../components/DoctorLayout';
import { patientService } from '../services/patientService';
import { prescriptionService } from '../services/prescriptionService';
import { authService } from '../services/authService';

const PrescriptionDetailsPage = () => {
    const navigate = useNavigate();
    const { id } = useParams(); // patientId

    const [patient, setPatient] = useState(null);
    const [prescriptions, setPrescriptions] = useState([]);
    const [loading, setLoading] = useState(true);

    useEffect(() => {
        if (!id) return;

        const fetchData = async () => {
            setLoading(true);
            try {
                // Step 0: Ensure patient details are loaded (Absolute Source of Truth: URL ID)
                const patientData = await patientService.getPatientById(id);
                if (patientData) setPatient(patientData);

                // Stage 1: PRIMARY - Fetch prescriptions for patient
                console.log(`[NETWORK] stage 1: Primary API getPrescriptionsByPatient(${id})`);
                let results = await prescriptionService.getPrescriptionsByPatient(id);
                
                // Stage 2: FALLBACK - Fetch via Doctor context if primary is empty
                if (!results || results.length === 0) {
                    console.log("[NETWORK] stage 2: Fallback API getPrescriptionsByDoctor context");
                    const currentUser = authService.getCurrentUser();
                    if (currentUser) {
                        const doctorId = currentUser.id || currentUser.user_id;
                        const allDoctorPrescriptions = await prescriptionService.getPrescriptionsByDoctor(doctorId);
                        
                        // Filter for this patient
                        results = (allDoctorPrescriptions || []).filter(p => 
                            String(p.patient_id) === String(id) || String(p.patient_display_id) === String(id)
                        );
                    }
                }

                // Stage 3: ENRICHMENT - Fetch medicine details if missing
                const finalSet = await Promise.all((results || []).map(async (p) => {
                    // Only enrich if no drugs found (Primary usually has them, Fallback doesn't)
                    if (!p.drugs || p.drugs.length === 0) {
                        console.log(`[NETWORK] stage 3: Enrichment needed for prescription ${p.id}`);
                        try {
                            const explanation = await prescriptionService.getExplanation(p.id);
                            
                            // Map the simplified data structure back to a drugs array
                            // AI explanation returns simplified_explanation.drugs
                            const enriched = explanation.simplified_explanation?.drugs || [];
                            
                            // Ensure properties are normalized for UI
                            const drugs = enriched.map(d => ({
                                name: d.drug_name || d.name,
                                dosage: d.strength || d.dosage || d.quantity, // backend sometimes calls it quantity
                                frequency: d.frequency,
                                duration: d.duration || (d.what_it_does ? 'As prescribed' : '')
                            }));

                            return { ...p, drugs };
                        } catch (err) {
                            console.error(`[NETWORK] Enrichment failed for ${p.id} (403 or Backend Error)`, err);
                            return { ...p, drugs: [] };
                        }
                    }
                    // Normalize standard API drug objects
                    const normalizedDrugs = (p.drugs || []).map(d => ({
                        name: d.drug_name || d.name,
                        dosage: d.strength || d.dosage || d.quantity,
                        frequency: d.frequency,
                        duration: d.duration
                    }));
                    return { ...p, drugs: normalizedDrugs };
                }));

                console.log("[NETWORK] Final merged prescriptions:", finalSet);
                setPrescriptions(finalSet);
                
            } catch (err) {
                console.error("[NETWORK] Critical failure in multi-stage fetch:", err);
            } finally {
                setLoading(false);
            }
        };

        fetchData();
    }, [id]);

    const patientName = patient ? (patient.full_name || patient.name) : 'Patient';
    const patientPID = patient ? (patient.pid || `PID-${String(id).padStart(4, '0')}`) : '...';

    return (
        <DoctorLayout>
            <div style={{ maxWidth: '900px', margin: '0 auto', width: '100%', paddingBottom: '100px' }}>
                {/* â”€â”€ Header â”€â”€ */}
                <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '40px' }}>
                    <div style={{ display: 'flex', alignItems: 'center', gap: '20px' }}>
                        <button onClick={() => navigate('/patients')} style={{
                            width: '40px', height: '40px', borderRadius: '50%', border: 'none',
                            background: 'transparent', display: 'flex', alignItems: 'center', justifyContent: 'center',
                            cursor: 'pointer'
                        }}>
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#111827" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
                                <path d="m15 18-6-6 6-6" />
                            </svg>
                        </button>
                        <div>
                            <h1 style={{ fontSize: '24px', fontWeight: '900', color: '#111827', margin: '0 0 6px 0' }}>{patientName}</h1>
                            <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
                                <span style={{ backgroundColor: '#E6FCFA', color: '#00BFB3', fontSize: '12px', fontWeight: '800', padding: '4px 8px', borderRadius: '6px' }}>
                                    {patientPID}
                                </span>
                                <span style={{ fontSize: '14px', fontWeight: '500', color: '#6B7280' }}>
                                    {patient ? `${patient.age || 'N/A'} yrs â€¢ ${patient.gender || 'N/A'}` : ''}
                                </span>
                            </div>
                        </div>
                    </div>
                    <button 
                        onClick={() => navigate('/create-prescription', { state: { patient } })}
                        style={{
                            backgroundColor: '#00E3D3', color: '#fff', border: 'none',
                            padding: '12px 20px', borderRadius: '14px', fontSize: '14px', fontWeight: '800',
                            cursor: 'pointer', display: 'flex', alignItems: 'center', gap: '8px'
                        }}
                    >
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Create Prescription
                    </button>
                </div>

                <h2 style={{ fontSize: '13px', fontWeight: '800', color: '#9CA3AF', textTransform: 'uppercase', letterSpacing: '0.1em', marginBottom: '24px' }}>
                    PRESCRIPTION DETAILS
                </h2>

                {/* â”€â”€ Timeline â”€â”€ */}
                <div style={{ position: 'relative', paddingLeft: '32px' }}>
                    <div style={{ position: 'absolute', left: '0', top: '10px', bottom: '0', width: '2px', backgroundColor: '#F3F4F6' }} />

                    {loading ? (
                        <p style={{ textAlign: 'center', padding: '40px', color: '#6B7280' }}>Loading details...</p>
                    ) : prescriptions.length === 0 ? (
                        <p style={{ textAlign: 'center', padding: '40px', color: '#9CA3AF', fontStyle: 'italic' }}>
                            No prescriptions found for this patient.
                        </p>
                    ) : prescriptions.map((record, index) => (
                        <div key={record.id} style={{ position: 'relative', marginBottom: '40px' }}>
                            {/* Dot */}
                            <div style={{
                                position: 'absolute', left: '-37px', top: '24px', width: '12px', height: '12px',
                                borderRadius: '50%', backgroundColor: '#00E3D3', border: '3px solid #fff', zIndex: 2
                            }} />

                            <div style={{ backgroundColor: '#fff', borderRadius: '24px', padding: '24px', border: '1.5px solid #F3F4F6', boxShadow: '0 4px 12px rgba(0,0,0,0.02)' }}>
                                <div style={{ marginBottom: '16px' }}>
                                    <span style={{ fontSize: '14px', fontWeight: '800', color: '#00BFB3' }}>
                                        {record.iso_created_at ? new Date(record.iso_created_at).toLocaleString('en-GB') : record.formatted_date}
                                    </span>
                                    <h3 style={{ fontSize: '18px', fontWeight: '900', color: '#111827', marginTop: '4px' }}>General Medicine</h3>
                                </div>

                                <div style={{ marginBottom: '16px' }}>
                                    <p style={{ fontSize: '11px', fontWeight: '800', color: '#9CA3AF', textTransform: 'uppercase', letterSpacing: '0.05em', marginBottom: '4px' }}>DIAGNOSIS</p>
                                    <p style={{ fontSize: '15px', fontWeight: '700', color: '#4B5563', margin: 0 }}>{record.diagnosis || 'No diagnosis recorded'}</p>
                                </div>

                                <div>
                                    <p style={{ fontSize: '11px', fontWeight: '800', color: '#9CA3AF', textTransform: 'uppercase', letterSpacing: '0.05em', marginBottom: '12px' }}>PRESCRIPTION</p>
                                    <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
                                        {record.drugs && record.drugs.length > 0 ? (
                                            record.drugs.map((drug, di) => (
                                                <div key={di} style={{ display: 'flex', alignItems: 'center', gap: '10px', backgroundColor: '#F9FAFB', padding: '10px 16px', borderRadius: '12px' }}>
                                                    <div style={{ backgroundColor: '#EEF2FF', padding: '6px', borderRadius: '8px' }}>
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F46E5" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round">
                                                            <path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/>
                                                        </svg>
                                                    </div>
                                                    <div>
                                                        <p style={{ fontSize: '14px', fontWeight: '800', color: '#111827', margin: 0 }}>
                                                            {drug.name} <span style={{ fontWeight: '500', color: '#6B7280', fontSize: '12px' }}>({drug.dosage})</span>
                                                        </p>
                                                        <p style={{ fontSize: '12px', fontWeight: '600', color: '#6B7280', margin: 0 }}>
                                                            {drug.frequency}{drug.duration ? ` â€” ${drug.duration}` : ''}
                                                        </p>
                                                    </div>
                                                </div>
                                            ))
                                        ) : (
                                            <p style={{ fontSize: '14px', fontStyle: 'italic', color: '#9CA3AF', margin: 0 }}>No medication details recorded.</p>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </DoctorLayout>
    );
};

export default PrescriptionDetailsPage;
